# Copia este archivo a .env y rellena con tus valores reales.
# No subas .env a Git (está en .gitignore).

# Supabase — servidor y cliente
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_PUBLISHABLE_KEY=tu_clave_anon_publicable

# Supabase — variables expuestas al cliente (Vite)
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=tu_clave_anon_publicable
VITE_SUPABASE_PROJECT_ID=bklnaeftoztcahfgxchl

# Solo servidor (nunca en el bundle del navegador)
# SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# URL pública de la app (webhook Twilio + enlaces)
PUBLIC_APP_URL=http://localhost:8080

# Twilio WhatsApp API
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=tu_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Opcional: URL exacta registrada en Twilio (si difiere de PUBLIC_APP_URL/api/webhooks/twilio)
# TWILIO_WEBHOOK_PUBLIC_URL=https://tu-dominio.com/api/webhooks/twilio
# Respuesta automática al recibir un mensaje (opcional)
# TWILIO_AUTO_REPLY_MESSAGE=Gracias por escribir. Ema te responderá en breve.
